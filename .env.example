# =============================================================================
# LLM Studio environment configuration (copy to .env and edit).
# All variables are optional — sensible defaults live in config/default.yaml.
# Every setting can be overridden with the LLMSTUDIO_ prefix.
# =============================================================================

# --- Storage -----------------------------------------------------------------
# Root directory for all runtime data (datasets, checkpoints, registry DB,
# downloaded models). Defaults to ./workspace next to the repo.
# LLMSTUDIO_HOME=/data/llmstudio

# --- Hugging Face ------------------------------------------------------------
# Token for downloading gated models (Llama, Gemma, ...). Create one at
# https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Where Hugging Face caches downloaded weights.
# HF_HOME=/data/llmstudio/hf_cache

# --- Assistant model ---------------------------------------------------------
# The instruct model that powers in-app hyperparameter / data-prep guidance.
# Downloaded during `llmstudio setup`. A smaller fallback is used automatically
# on low-VRAM machines.
# LLMSTUDIO_ASSISTANT__MODEL_ID=Qwen/Qwen2.5-7B-Instruct
# LLMSTUDIO_ASSISTANT__FALLBACK_MODEL_ID=Qwen/Qwen2.5-3B-Instruct
# Set to false to disable the LLM assistant entirely (heuristics still work).
# LLMSTUDIO_ASSISTANT__ENABLED=true

# --- Server ------------------------------------------------------------------
# LLMSTUDIO_SERVER__HOST=0.0.0.0
# LLMSTUDIO_SERVER__PORT=7860
# Create a public share link (Gradio tunnel). Keep false on shared servers.
# LLMSTUDIO_SERVER__SHARE=false
# Optional basic-auth, format "user:password".
# LLMSTUDIO_SERVER__AUTH=

# --- Logging -----------------------------------------------------------------
# LLMSTUDIO_LOG_LEVEL=INFO
